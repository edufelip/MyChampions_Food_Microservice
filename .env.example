# ─── MyChampions Food Microservice – Environment Variables ───────────────────
# Copy this file to .env and fill in real values before running the service.
# Never commit .env to version control.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
# Number of reverse-proxy hops to trust for client IP extraction (Nginx=1)
# TRUST_PROXY_HOPS=1

# ── Firebase ─────────────────────────────────────────────────────────────────
# Service account JSON encoded as base64:
#   base64 -i path/to/serviceAccountKey.json | tr -d '\n'
# Or paste the raw JSON string (single line, escaped).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── FatSecret API ─────────────────────────────────────────────────────────────
# OAuth2 client credentials from https://platform.fatsecret.com/api/
FATSECRET_CLIENT_ID=
FATSECRET_CLIENT_SECRET=

# (Optional overrides – defaults shown)
# FATSECRET_API_URL=https://platform.fatsecret.com/rest/server.api
# FATSECRET_TOKEN_URL=https://oauth.fatsecret.com/connect/token

# ── Token Cache ───────────────────────────────────────────────────────────────
# Seconds before token expiry to trigger a proactive refresh
# TOKEN_EXPIRY_MARGIN_SECONDS=60

# ── Upstream HTTP ─────────────────────────────────────────────────────────────
# Request timeout in milliseconds for FatSecret API calls
# UPSTREAM_TIMEOUT_MS=10000
# Max retry attempts for transient upstream errors (0 = no retries)
# UPSTREAM_RETRIES=2

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# Window size in milliseconds (default: 60 seconds)
# RATE_LIMIT_WINDOW_MS=60000
# Max requests per IP per window
# RATE_LIMIT_MAX=60

# ── Input Validation ──────────────────────────────────────────────────────────
# Maximum allowed maxResults from client (server caps to this value)
# MAX_RESULTS_LIMIT=50

# ── Translation + Redis Cache ─────────────────────────────────────────────────
# When true, GOOGLE_TRANSLATE_API_KEY must be set.
ENABLE_TRANSLATION_PIPELINE=true
GOOGLE_TRANSLATE_API_KEY=
# GOOGLE_TRANSLATE_BASE_URL=https://translation.googleapis.com/language/translate/v2
# TRANSLATION_TIMEOUT_MS=5000
# TRANSLATION_RETRIES=2
# TRANSLATION_RETRY_BASE_DELAY_MS=150
REDIS_URL=redis://localhost:6379
# QUERY_TRANSLATION_CACHE_TTL_SECONDS=2592000
